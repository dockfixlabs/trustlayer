# ════════════════════════════════════════════════
# TrustLayer — Environment Variables
# نسخ هذا الملف إلى .env وأدخل القيم الحقيقية
# ════════════════════════════════════════════════

# ── ACP Agent Credentials (اطلب من المستخدم) ──
WHITELISTED_WALLET_PRIVATE_KEY=your_private_key_here_without_0x
AGENT_WALLET_ADDRESS=0xYourAgentWalletAddress
AGENT_ENTITY_ID=your_entity_id_here

# ── Network ──
# "mainnet" أو "testnet"
NETWORK=testnet

# ── API Server ──
API_PORT=8000
API_HOST=0.0.0.0

# ── 8004scan API ──
SCAN_API_BASE=https://8004scan.io/api/v1

# ── TrustLayer Agent Settings ──
TRUSTLAYER_SERVICE_PRICE_USDC=0.01
TRUSTLAYER_SLA_MINUTES=3

# ── Update Interval (minutes) ──
UPDATE_INTERVAL_MINUTES=15
